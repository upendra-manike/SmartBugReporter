{
  "manifest_version": 3,
  "name": "Smart Bug Reporter",
  "version": "1.0.1",
  "description": "One-click bug capture: screenshot, console logs, network requests, browser info. Generate Jira or GitHub issues.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Bug Reporter"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-capture.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
